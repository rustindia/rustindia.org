---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

const dayOne = [
  {
    time: "09:00 AM",
    duration: "60 min",
    tags: ["Registration"],
    title: "Registration and breakfast",
    summary: "Grab your badge, settle in, and meet Rustaceans before the conference day begins.",
    speaker: "Venue Team",
    role: "Main lobby check-in",
    location: "Main Lobby",
    initials: "VT",
    badgeBg: "#ffd38a",
    badgeFg: "#4b2217",
  },
  {
    time: "10:00 AM",
    duration: "90 min",
    tags: ["Keynote", "Systems", "Beginner"],
    title: "The future of Rust in systems",
    summary: "A big-picture keynote on reliability, memory safety, and where Rust keeps winning in production systems.",
    speaker: "Aisha Joshi",
    role: "Principal Engineer, FerrisCorp",
    location: "Main Stage",
    initials: "AJ",
    badgeBg: "#ffc069",
    badgeFg: "#4b2217",
  },
  {
    time: "11:30 AM",
    duration: "45 min",
    tags: ["Web", "Advanced"],
    title: "Building safe web servers with Axum",
    summary: "Routing, middleware, and state management patterns for production Rust web services.",
    speaker: "Rahul Kumar",
    role: "Backend Lead, StartUp Inc",
    location: "Track A Room",
    initials: "RK",
    badgeBg: "#ef745d",
    badgeFg: "#fff8ef",
  },
];

const dayTwo = [
  {
    time: "09:30 AM",
    duration: "45 min",
    tags: ["Community"],
    title: "Contributor breakfast and open source meetups",
    summary: "A softer start focused on maintainers, local groups, and contributors meeting before the formal sessions.",
    speaker: "Rust India Community",
    role: "Community-hosted meetup block",
    location: "Hallway Space",
    initials: "RI",
    badgeBg: "#ffd38a",
    badgeFg: "#4b2217",
  },
  {
    time: "11:00 AM",
    duration: "60 min",
    tags: ["Tooling", "Intermediate"],
    title: "Making Rust developer tooling faster",
    summary: "Practical improvements around cargo workflows, local feedback loops, and CI time reduction.",
    speaker: "Maya Sen",
    role: "Tooling Engineer, Compile Labs",
    location: "Main Stage",
    initials: "MS",
    badgeBg: "#ea9b7d",
    badgeFg: "#fff8ef",
  },
  {
    time: "01:30 PM",
    duration: "45 min",
    tags: ["Embedded", "Senior"],
    title: "Shipping embedded Rust on real hardware",
    summary: "Firmware architecture, safety boundaries, and the tradeoffs that appear once hardware enters the loop.",
    speaker: "Vikram Rao",
    role: "Lead Embedded Engineer, Vortex",
    location: "Track B Room",
    initials: "VR",
    badgeBg: "#3d221a",
    badgeFg: "#fff8ef",
  },
];
---

<BaseLayout
  title="Schedule | Rust India 2026"
  description="Rust India 2026 schedule preview for the Bengaluru conference weekend on April 18 and community programming around it."
>
  <SiteHeader currentPath="/schedule" />

  <main class="site-main">
    <section class="schedule-page section-shell">
      <div class="schedule-layout">
        <aside class="schedule-side">
          <p class="section-label">Schedule</p>
          <h1 class="schedule-side__title">Schedule</h1>
          <p class="schedule-side__lede">Plan your Rust India conference flow in Bengaluru across the main day and community programming around it.</p>

          <div class="schedule-day-switches">
            <button type="button" class="schedule-day-switch is-active" data-day-switch="day-one">
              Day 1
              <span>April 18</span>
            </button>
            <button type="button" class="schedule-day-switch" data-day-switch="day-two">
              Day 2
              <span>Community Track</span>
            </button>
          </div>

          <p class="schedule-side__note">CFPs are closed. Final speaker order and room details will be published here.</p>
        </aside>

        <div class="schedule-stack">
          <div class="schedule-day" data-day-panel="day-one">
            {
              dayOne.map((item) => (
                <article class="schedule-entry frame-panel" style={`--speaker-bg:${item.badgeBg}; --speaker-fg:${item.badgeFg};`}>
                  <div class="schedule-entry__time">
                    <strong>{item.time}</strong>
                    <span>{item.duration}</span>
                  </div>

                  <div class="schedule-entry__body">
                    <div class="schedule-entry__tags">
                      {item.tags.map((tag) => <span class="tag">{tag}</span>)}
                    </div>

                    <h2 class="schedule-entry__title">{item.title}</h2>
                    <p class="schedule-entry__summary">{item.summary}</p>

                    <div class="schedule-entry__footer">
                      <div class="schedule-entry__speaker">
                        <div class="schedule-entry__avatar">{item.initials}</div>
                        <div>
                          <div class="schedule-entry__speaker-name">{item.speaker}</div>
                          <div class="schedule-entry__speaker-role">{item.role}</div>
                        </div>
                      </div>

                      <div class="schedule-entry__location">{item.location}</div>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>

          <div class="schedule-day hidden" data-day-panel="day-two">
            {
              dayTwo.map((item) => (
                <article class="schedule-entry frame-panel" style={`--speaker-bg:${item.badgeBg}; --speaker-fg:${item.badgeFg};`}>
                  <div class="schedule-entry__time">
                    <strong>{item.time}</strong>
                    <span>{item.duration}</span>
                  </div>

                  <div class="schedule-entry__body">
                    <div class="schedule-entry__tags">
                      {item.tags.map((tag) => <span class="tag">{tag}</span>)}
                    </div>

                    <h2 class="schedule-entry__title">{item.title}</h2>
                    <p class="schedule-entry__summary">{item.summary}</p>

                    <div class="schedule-entry__footer">
                      <div class="schedule-entry__speaker">
                        <div class="schedule-entry__avatar">{item.initials}</div>
                        <div>
                          <div class="schedule-entry__speaker-name">{item.speaker}</div>
                          <div class="schedule-entry__speaker-role">{item.role}</div>
                        </div>
                      </div>

                      <div class="schedule-entry__location">{item.location}</div>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    const daySwitches = Array.from(document.querySelectorAll("[data-day-switch]"));
    const dayPanels = Array.from(document.querySelectorAll("[data-day-panel]"));

    if (daySwitches.length && dayPanels.length) {
      daySwitches.forEach((button) => {
        button.addEventListener("click", () => {
          const selected = button.getAttribute("data-day-switch");

          daySwitches.forEach((item) => item.classList.toggle("is-active", item === button));
          dayPanels.forEach((panel) => {
            panel.classList.toggle("hidden", panel.getAttribute("data-day-panel") !== selected);
          });
        });
      });
    }
  </script>
</BaseLayout>
