---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
---

<BaseLayout
  title="Sponsors | Rust India 2026"
  description="Sponsor Rust India 2026 in Bengaluru and reach Rust engineers, maintainers, and hiring teams across India."
>
  <SiteHeader currentPath="/sponsors" />

  <main class="site-main">
    <section class="page-hero section-shell">
      <div class="page-hero__inner">
        <div class="page-hero__copy">
          <p class="section-label">Sponsors</p>
          <h1 class="page-hero__title">Sponsor a conference people will actually remember.</h1>
          <p class="page-hero__lede">
            Rust India is designed around signal: focused talks, hiring visibility, and high-intent conversations with
            engineers who care deeply about systems work.
          </p>

          <div class="page-hero__actions">
            <a href="mailto:sponsor@rustindia.org" class="btn btn-primary">Request Sponsor Deck</a>
            <a href="/jobs" class="btn btn-secondary">See Jobs Page</a>
          </div>
        </div>
      </div>
    </section>

    <section class="detail-band section-shell">
      <div class="detail-band__panel frame-panel">
        <p class="detail-band__eyebrow">Why Sponsor Rust India</p>
        <h2 class="detail-band__title">Reach Rust builders without expo noise.</h2>

        <div class="detail-band__rows">
          <div class="detail-band__row">
            <strong>Hiring visibility</strong>
            <p>
              Featured roles on the jobs page, sponsor mentions on-site, and direct contact with attendees who already
              care about Rust in production.
            </p>
          </div>
          <div class="detail-band__row">
            <strong>Stage alignment</strong>
            <p>
              Support a serious technical conference without diluting it. Sponsorship fits the event instead of fighting
              it for attention.
            </p>
          </div>
          <div class="detail-band__row">
            <strong>Community trust</strong>
            <p>
              Rust India is community-shaped. Sponsors show up as collaborators, not as a wall of booths and repetitive
              sales messaging.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="page-section__grid">
        <article class="page-section__panel frame-panel">
          <p class="section-label">Sponsor Surfaces</p>
          <h2 class="panel-heading">Choose a presence that fits your team.</h2>

          <div class="process-list">
            <div class="process-row">
              <strong>Main partner</strong>
              <p>Brand placement across the site, stage recognition, venue presence, and priority hiring visibility.</p>
            </div>
            <div class="process-row">
              <strong>Hiring partner</strong>
              <p>Jobs board coverage, sponsor callouts, and a clear path for attendees to connect with your team.</p>
            </div>
            <div class="process-row">
              <strong>Community support</strong>
              <p>Help fund community participation, hallway spaces, or smaller conference moments that matter to attendees.</p>
            </div>
          </div>
        </article>

        <article class="page-section__panel frame-panel">
          <p class="section-label">What We Need From You</p>
          <h2 class="panel-heading">Keep the coordination simple.</h2>

          <div class="process-list">
            <div class="process-row">
              <strong>Team goals</strong>
              <p>Tell us whether you are focused on hiring, brand awareness, community support, or a mix of those outcomes.</p>
            </div>
            <div class="process-row">
              <strong>Logistics</strong>
              <p>We will line up deck details, timelines, invoice flow, and the right site placements with you directly.</p>
            </div>
            <div class="process-row">
              <strong>Fast contact</strong>
              <p>We prefer direct email coordination so sponsor packages stay customized and lightweight.</p>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="community-band section-shell">
      <div class="community-band__panel accent-panel">
        <div class="community-band__content">
          <p class="section-label">Sponsor Contact</p>
          <h2 class="panel-heading">Ready to support Rust India 2026?</h2>
          <p class="panel-copy">
            Send a note with your team name, sponsorship goals, and hiring plans. We will reply with the deck and the
            right package options.
          </p>

          <div class="community-band__actions">
            <a href="mailto:sponsor@rustindia.org" class="btn btn-secondary">Email sponsor@rustindia.org</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
