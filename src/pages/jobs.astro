---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

interface Job {
  badge: string;
  badgeBg: string;
  badgeFg: string;
  title: string;
  company: string;
  posted: string;
  workMode: string;
  workModeLabel: string;
  level: string;
  levelLabel: string;
  tags: string[];
  summary: string;
  actionHref: string;
  actionLabel: string;
}

const filterGroups = [
  {
    id: "workMode",
    title: "Work Mode",
    options: [
      { value: "remote", label: "Remote" },
      { value: "hybrid", label: "Hybrid" },
      { value: "onsite", label: "On-site (India)" },
    ],
  },
  {
    id: "level",
    title: "Experience Level",
    options: [
      { value: "senior", label: "Senior" },
      { value: "mid", label: "Mid-Level" },
      { value: "junior", label: "Junior" },
    ],
  },
];

const jobs: Job[] = [];

const inviteCard = {
  badge: "+",
  title: "Want to add a role here?",
  company: "Rust India Jobs Board",
  posted: "Submissions open",
  summary: "Mail the team with the role, company, work mode, and level. We will publish relevant Rust openings on the board.",
  tags: ["Submit a job", "Rust hiring", "Hiring"],
  actionHref: "mailto:jobs@rustindia.org?subject=Rust%20India%20Job%20Submission",
  actionLabel: "Submit a Job",
};
---

<BaseLayout
  title="Jobs | Rust India 2026"
  description="Sponsor jobs and Rust hiring roles for engineers across India, highlighted through Rust India 2026."
>
  <SiteHeader currentPath="/jobs" />

  <main class="site-main">
    <section class="jobs-header section-shell">
      <p class="section-label">Jobs Board</p>
      <h1 class="jobs-header__title">Posted Jobs</h1>
      <p class="jobs-header__lede">Rust-focused roles from teams hiring around the conference. Use the filters to narrow by work mode and experience level.</p>
    </section>

    <section class="jobs-board section-shell">
      <aside class="jobs-filter frame-panel">
        <h2 class="jobs-filter__title">Filters</h2>
        <p class="jobs-filter__intro">Filter the board by work mode and experience level. Counts update live as jobs are added.</p>

        <form class="jobs-filter__form" data-jobs-filters>
          {
            filterGroups.map((group) => (
              <div class="filter-group">
                <div class="filter-group__head">
                  <h3>{group.title}</h3>
                  <span class="filter-group__meta" data-filter-selected={group.id}></span>
                </div>

                <div class="filter-options">
                  {
                    group.options.map((option) => (
                      <div class="filter-option">
                        <label class="filter-option__label">
                          <input checked type="checkbox" value={option.value} data-filter-group={group.id} />
                          <span class="filter-option__knob" aria-hidden="true"></span>
                          <span class="filter-option__text">{option.label}</span>
                        </label>
                        <span class="filter-count" data-filter-count={`${group.id}:${option.value}`}></span>
                      </div>
                    ))
                  }
                </div>
              </div>
            ))
          }
        </form>

        <div class="jobs-filter__actions">
          <button type="button" class="btn btn-primary" data-filter-reset>Reset Filters</button>
          <a href={inviteCard.actionHref} class="btn btn-primary">{inviteCard.actionLabel}</a>
        </div>
      </aside>

      <div class="jobs-board__main">
        <div class="jobs-results frame-panel" role="status" aria-live="polite">
          <p class="section-label">Open Roles</p>
          <h2 class="jobs-results__title"><span data-jobs-count>{jobs.length}</span> open roles</h2>
          <p class="jobs-results__note" data-jobs-state>Filter the current postings or submit a job to be listed.</p>
        </div>

        <div class="jobs-list">
          {
            jobs.map((job) => (
              <article
                class="job-row frame-panel"
                style={`--badge-bg:${job.badgeBg}; --badge-fg:${job.badgeFg};`}
                data-job-card
                data-work-mode={job.workMode}
                data-level={job.level}
              >
                <div class="job-row__lead">
                  <div class="job-row__badge">{job.badge}</div>

                  <div class="job-row__content">
                    <div class="job-row__headline">
                      <h2 class="job-row__title">{job.title}</h2>
                    </div>

                    <div class="job-row__meta">
                      <span class="job-row__company">{job.company}</span>
                      <span class="job-row__posted">{job.posted}</span>
                      <span class="job-row__meta-pill">{job.workModeLabel}</span>
                      <span class="job-row__meta-pill">{job.levelLabel}</span>
                    </div>

                    <div class="job-row__tags">
                      {job.tags.map((tag) => <span class="tag">{tag}</span>)}
                    </div>

                    <p class="job-row__summary">{job.summary}</p>
                  </div>

                  <a href={job.actionHref} class="btn btn-secondary job-row__action">
                    {job.actionLabel}
                  </a>
                </div>
              </article>
            ))
          }

          <article class="job-row job-row--empty frame-panel" data-jobs-empty hidden>
            <p class="section-label">No Jobs Yet</p>
            <h2 class="job-row__title">There are no live job posts on the board right now.</h2>
            <p class="job-row__summary">You can still adjust the filters, and hiring teams can use the submit flow below to add the first opening.</p>
          </article>

          <article class="job-row job-row--invite accent-panel">
            <div class="job-row__lead">
              <div class="job-row__badge job-row__badge--light">{inviteCard.badge}</div>

              <div class="job-row__content">
                <div class="job-row__headline">
                  <h2 class="job-row__title">{inviteCard.title}</h2>
                </div>

                <div class="job-row__meta">
                  <span class="job-row__company">{inviteCard.company}</span>
                  <span class="job-row__posted">{inviteCard.posted}</span>
                </div>

                <div class="job-row__tags">
                  {inviteCard.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>

                <p class="job-row__summary">{inviteCard.summary}</p>
              </div>

              <a href={inviteCard.actionHref} class="btn btn-primary job-row__action">
                {inviteCard.actionLabel}
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  const filterForm = document.querySelector("[data-jobs-filters]");
  const jobCards = Array.from(document.querySelectorAll("[data-job-card]"));
  const resultsCount = document.querySelector("[data-jobs-count]");
  const resultsState = document.querySelector("[data-jobs-state]");
  const emptyState = document.querySelector("[data-jobs-empty]");
  const resetButton = document.querySelector("[data-filter-reset]");
  const selectedMeta = new Map(
    Array.from(document.querySelectorAll("[data-filter-selected]")).map((node) => [node.dataset.filterSelected, node]),
  );
  const countNodes = new Map(
    Array.from(document.querySelectorAll("[data-filter-count]")).map((node) => [node.dataset.filterCount, node]),
  );

  if (filterForm && resultsCount && resultsState && emptyState && resetButton) {
    const inputs = Array.from(filterForm.querySelectorAll("input[data-filter-group]"));
    const groups = [...new Set(inputs.map((input) => input.dataset.filterGroup).filter(Boolean))];

    const selectionsFor = (excludeGroup) =>
      groups.reduce((acc, group) => {
        if (group === excludeGroup) {
          return acc;
        }

        acc[group] = inputs
          .filter((input) => input.dataset.filterGroup === group && input.checked)
          .map((input) => input.value);
        return acc;
      }, {});

    const matchesSelections = (card, selections) =>
      groups.every((group) => {
        const allowed = selections[group] ?? [];
        if (!allowed.length) {
          return false;
        }

        return allowed.includes(card.dataset[group]);
      });

    const updateGroupMeta = () => {
      groups.forEach((group) => {
        const groupInputs = inputs.filter((input) => input.dataset.filterGroup === group);
        const checked = groupInputs.filter((input) => input.checked);
        const meta = selectedMeta.get(group);

        if (meta) {
          meta.textContent = `${checked.length}/${groupInputs.length} on`;
        }
      });
    };

    const updateOptionCounts = () => {
      groups.forEach((group) => {
        const groupInputs = inputs.filter((input) => input.dataset.filterGroup === group);
        const otherSelections = selectionsFor(group);

        groupInputs.forEach((input) => {
          const count = jobCards.filter((card) => {
            const matchesOtherGroups = groups.every((otherGroup) => {
              if (otherGroup === group) {
                return true;
              }

              const allowed = otherSelections[otherGroup] ?? [];
              if (!allowed.length) {
                return false;
              }

              return allowed.includes(card.dataset[otherGroup]);
            });

            return matchesOtherGroups && card.dataset[group] === input.value;
          }).length;

          const countKey = `${group}:${input.value}`;
          const countNode = countNodes.get(countKey);
          if (countNode) {
            countNode.textContent = String(count);
            countNode.dataset.empty = count === 0 ? "true" : "false";
          }

          input.closest(".filter-option")?.toggleAttribute("data-empty", count === 0);
        });
      });
    };

    const updateJobsBoard = () => {
      const activeSelections = selectionsFor();
      let visibleCount = 0;

      jobCards.forEach((card) => {
        const visible = matchesSelections(card, activeSelections);
        card.hidden = !visible;
        if (visible) {
          visibleCount += 1;
        }
      });

      emptyState.hidden = visibleCount !== 0;
      resultsCount.textContent = String(visibleCount);
      resultsState.textContent =
        visibleCount === 0
          ? "No jobs match the current filters yet. Reset the filters or submit a job."
          : `${visibleCount} ${visibleCount === 1 ? "role matches" : "roles match"} your current filters.`;

      updateGroupMeta();
      updateOptionCounts();
    };

    filterForm.addEventListener("change", updateJobsBoard);
    resetButton.addEventListener("click", () => {
      inputs.forEach((input) => {
        input.checked = true;
      });
      updateJobsBoard();
    });

    updateJobsBoard();
  }
</script>
