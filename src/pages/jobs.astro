---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

const jobs = [
  {
    badge: "AC",
    badgeBg: "#ffc069",
    badgeFg: "#4b2217",
    title: "Senior Rustacean",
    company: "Apollo Corp",
    posted: "Posted 2d ago",
    tags: ["Remote", "Senior", "Systems"],
    summary: "Lead systems-facing Rust services for a sponsor team focused on infra, performance, and long-running workloads.",
  },
  {
    badge: "ND",
    badgeBg: "#ea9b7d",
    badgeFg: "#fff8ef",
    title: "Rust Backend Engineer",
    company: "Nexus Data",
    posted: "Posted 4d ago",
    tags: ["Remote", "Mid-Level", "Web"],
    summary: "Build backend APIs, queue workers, and service tooling with Rust for data-heavy product teams.",
  },
  {
    badge: "VX",
    badgeBg: "#3d221a",
    badgeFg: "#fff8ef",
    title: "Lead Embedded Dev",
    company: "Vortex Hardware",
    posted: "Posted 1w ago",
    tags: ["On-site (India)", "Senior", "Embedded"],
    summary: "Own embedded Rust delivery across hardware interfaces, telemetry pipelines, and firmware reliability work.",
  },
];
---

<BaseLayout
  title="Jobs | Rust India 2026"
  description="Sponsor jobs and Rust hiring roles for engineers across India, highlighted through Rust India 2026."
>
  <SiteHeader currentPath="/jobs" />

  <main class="site-main">
    <section class="jobs-header section-shell">
      <p class="section-label">Jobs Board</p>
      <h1 class="jobs-header__title">Sponsor Jobs</h1>
      <p class="jobs-header__lede">Find your next role in the Rust ecosystem through the teams supporting Rust India 2026.</p>
    </section>

    <section class="jobs-board section-shell">
      <aside class="jobs-filter frame-panel">
        <h2 class="jobs-filter__title">Filters</h2>
        <p class="jobs-filter__intro">A simple view of the roles sponsors are currently pushing on the Rust India board.</p>

        <div class="filter-group">
          <h2>Location</h2>
          <div class="filter-options">
            <div class="filter-option">
              <label><input checked type="checkbox" />Remote</label>
              <span class="filter-count">12</span>
            </div>
            <div class="filter-option">
              <label><input type="checkbox" />On-site (India)</label>
              <span class="filter-count">5</span>
            </div>
            <div class="filter-option">
              <label><input type="checkbox" />Hybrid</label>
              <span class="filter-count">3</span>
            </div>
          </div>
        </div>

        <div class="filter-group">
          <h2>Experience Level</h2>
          <div class="filter-options">
            <div class="filter-option">
              <label><input checked type="checkbox" />Senior</label>
            </div>
            <div class="filter-option">
              <label><input type="checkbox" />Mid-Level</label>
            </div>
            <div class="filter-option">
              <label><input type="checkbox" />Junior</label>
            </div>
          </div>
        </div>

        <div class="jobs-filter__actions">
          <button type="button" class="btn btn-primary">Apply Filters</button>
          <a href="mailto:sponsor@rustindia.org" class="btn btn-secondary">Sponsor The Jobs Board</a>
        </div>
      </aside>

      <div class="jobs-list">
        {
          jobs.map((job) => (
            <article class="job-row frame-panel" style={`--badge-bg:${job.badgeBg}; --badge-fg:${job.badgeFg};`}>
              <div class="job-row__lead">
                <div class="job-row__badge">{job.badge}</div>

                <div>
                  <div class="job-row__headline">
                    <h2 class="job-row__title">{job.title}</h2>
                    <span class="job-row__company">{job.company}</span>
                    <span class="job-row__posted">{job.posted}</span>
                  </div>

                  <div class="job-row__tags">
                    {job.tags.map((tag) => <span class="tag">{tag}</span>)}
                  </div>

                  <p class="job-row__summary">{job.summary}</p>
                </div>

                <a href="mailto:jobs@rustindia.org" class="btn btn-secondary job-row__action">Apply</a>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
