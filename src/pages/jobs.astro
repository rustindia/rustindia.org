const sponsoredJobs = [
// {
//   title: "Principal Rust Platform Engineer (Sponsored)",
//   company: "Placeholder Cloud Systems",
//   city: "Bengaluru",
//   workMode: "Hybrid (2 days on-site)",
//   type: "Full-time",
//   focus: "Runtime Performance",
//   level: "Principal",
// //  compensation: "INR 70-95 LPA + ESOPs",
//   summary: "Lead a Rust platform rewrite for high-throughput data services, memory profiling, and SLO ownership.",
