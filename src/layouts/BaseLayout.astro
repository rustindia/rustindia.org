---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Rust India Community",
  description = "Rust India Conference in Bangalore - April 18, 2026."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="grain-overlay" aria-hidden="true"></div>
    <slot />
  </body>
</html>
