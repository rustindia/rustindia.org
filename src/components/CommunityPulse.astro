<section class="home-support section-shell">
  <article id="mailing-list" class="home-support__block">
    <p class="section-label">Mailing List</p>
    <h2 class="section-title">Get tickets, speakers, and venue updates first.</h2>
    <p class="home-support__lead">
      We only send important conference updates. That means tickets, speaker announcements, schedule drops, and venue
      details. Nothing else.
    </p>

    <form
      class="mailing-form"
      action="https://docs.google.com/forms/d/e/1FAIpQLSf9QQD3qbXNT7pnjCFeJGM6eRfleFxVGc1_-vJSBjRxmeRb-A/formResponse"
      method="POST"
      target="hidden_iframe"
    >
      <label class="visually-hidden" for="email">Email</label>
      <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off" />
      <input
        id="email"
        type="email"
        name="entry.2110698367"
        required
        placeholder="you@company.com"
        autocomplete="email"
      />
      <button type="submit" data-signup-button class="btn btn-primary">Join Mailing List</button>
    </form>

    <p class="mailing-note">Conference updates only.</p>
    <p data-signup-msg aria-live="polite" class="mailing-note mailing-status hidden">
      Submission sent. We will share only key conference updates.
    </p>

    <iframe name="hidden_iframe" style="display:none;"></iframe>
  </article>

  <article class="home-support__block">
    <p class="section-label">Sponsors</p>
    <h2 class="section-title">Want your team on the Rust India site and jobs board?</h2>
    <p class="home-support__lead">
      Sponsor packages focus on visibility that matters: a place on the sponsor page, hiring presence on the jobs
      board, and real contact with Rust builders in India.
    </p>

    <div class="home-hero__actions">
      <a href="/sponsors" class="btn btn-primary">See Sponsor Page</a>
      <a href="mailto:sponsor@rustindia.org" class="btn btn-secondary">Contact Sponsors</a>
    </div>
  </article>
</section>

<section class="section-shell">
  <div class="home-community accent-panel">
    <div class="home-community__content">
      <p class="section-label">Community Hub</p>
      <h2 class="section-title">Join the Rust India Discord before conference week.</h2>
      <p>Meet future attendees, follow schedule updates, and start conversations with the Rust India community now.</p>

      <div class="home-community__actions">
        <a href="https://discord.gg/rustindia" class="btn btn-secondary" target="_blank" rel="noreferrer">Join Discord Community</a>
      </div>
    </div>
  </div>
</section>

<script>
  const signupSection = document.querySelector("#mailing-list");
  const signupForm = signupSection?.querySelector("form");
  const signupMessage = signupSection?.querySelector("[data-signup-msg]");
  const signupButton = signupSection?.querySelector("[data-signup-button]");
  const signupFrame = signupSection?.querySelector('iframe[name="hidden_iframe"]');

  if (signupForm && signupMessage && signupButton && signupFrame) {
    let isSubmitting = false;
    let fallbackTimer = 0;

    const finalizeSubmission = (message) => {
      if (fallbackTimer) {
        window.clearTimeout(fallbackTimer);
        fallbackTimer = 0;
      }

      isSubmitting = false;
      signupButton.disabled = false;
      signupButton.textContent = "Join Mailing List";
      signupForm.reset();
      signupMessage.textContent = message;
      signupMessage.classList.remove("hidden");
    };

    signupFrame.addEventListener("load", () => {
      if (!isSubmitting) return;
      finalizeSubmission("Submission received. Watch your inbox for Rust India updates.");
    });

    signupForm.addEventListener("submit", (event) => {
      if (isSubmitting) {
        event.preventDefault();
        return;
      }

      isSubmitting = true;
      signupButton.disabled = true;
      signupButton.textContent = "Sending...";
      signupMessage.classList.add("hidden");

      fallbackTimer = window.setTimeout(() => {
        if (!isSubmitting) return;
        finalizeSubmission("Submission sent. If nothing arrives later, please try again.");
      }, 4500);
    });
  }
</script>
