<script>
  const pulseCards = document.querySelectorAll("[data-pulse]");

  pulseCards.forEach((card) => {
    card.addEventListener("mouseenter", () => {
      pulseCards.forEach((el) => el.classList.remove("is-active"));
      card.classList.add("is-active");
    });
  });
</script>
