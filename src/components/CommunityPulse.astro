<section class="page-section section-shell">
  <div class="page-section__grid">
    <article id="mailing-list" class="page-section__panel frame-panel">
      <p class="section-label">Mailing List</p>
      <h2 class="panel-heading">Get ticket drops and speaker updates first.</h2>
      <p class="panel-copy">
        The mailing list is intentionally quiet. You will only hear from us for tickets, speaker announcements, venue
        details, and other important conference updates.
      </p>

      <form
        class="mailing-form"
        action="https://docs.google.com/forms/d/e/1FAIpQLSf9QQD3qbXNT7pnjCFeJGM6eRfleFxVGc1_-vJSBjRxmeRb-A/formResponse"
        method="POST"
        target="hidden_iframe"
      >
        <label class="visually-hidden" for="email">Email</label>
        <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off" />
        <input
          id="email"
          type="email"
          name="entry.2110698367"
          required
          placeholder="you@company.com"
          autocomplete="email"
        />
        <button type="submit" data-signup-button class="btn btn-primary">Join The Mailing List</button>
      </form>

      <p class="mailing-note">Conference updates only. No spam, no weekly drip, no marketing detours.</p>
      <p data-signup-msg aria-live="polite" class="mailing-note mailing-status hidden">
        Submission sent. We will share only key conference updates.
      </p>

      <iframe name="hidden_iframe" style="display:none;"></iframe>
    </article>

    <article class="page-section__panel frame-panel">
      <p class="section-label">Sponsors</p>
      <h2 class="panel-heading">Put your team in front of Rust builders in India.</h2>
      <p class="panel-copy">
        Rust India sponsorship stays focused: stage presence, hiring visibility, meaningful on-site conversations, and
        a jobs board that feels integrated instead of bolted on.
      </p>

      <div class="support-list">
        <div class="support-row">
          <strong>Hiring visibility</strong>
          <p>Featured roles on the jobs page, sponsor mentions on-site, and direct access to engineers already invested in Rust.</p>
        </div>
        <div class="support-row">
          <strong>Community presence</strong>
          <p>Support the conference without drowning the experience in sponsor clutter or generic expo noise.</p>
        </div>
        <div class="support-row">
          <strong>Fast coordination</strong>
          <p>Reach out directly for the sponsor deck, hiring packages, and custom support around talks or community grants.</p>
        </div>
      </div>

      <div class="hero__actions">
        <a href="/sponsors" class="btn btn-secondary">See Sponsor Options</a>
        <a href="mailto:sponsor@rustindia.org" class="btn btn-primary">Contact Sponsors</a>
      </div>
    </article>
  </div>
</section>

<section class="community-band section-shell">
  <div class="community-band__panel accent-panel">
    <div class="community-band__content">
      <p class="section-label">Community Hub</p>
      <h2 class="panel-heading">Join the Rust India Discord before the conference does.</h2>
      <p class="panel-copy">
        Introduce yourself, find other attendees, share CFP drafts, ask venue questions, and meet the people who will
        be in the room in Bengaluru.
      </p>

      <div class="community-band__actions">
        <a href="https://discord.gg/rustindia" class="btn btn-secondary" target="_blank" rel="noreferrer">Join Discord Community</a>
      </div>
    </div>
  </div>
</section>

<script>
  const signupSection = document.querySelector("#mailing-list");
  const signupForm = signupSection?.querySelector("form");
  const signupMessage = signupSection?.querySelector("[data-signup-msg]");
  const signupButton = signupSection?.querySelector("[data-signup-button]");
  const signupFrame = signupSection?.querySelector('iframe[name="hidden_iframe"]');

  if (signupForm && signupMessage && signupButton && signupFrame) {
    let isSubmitting = false;
    let fallbackTimer = 0;

    const finalizeSubmission = (message) => {
      if (fallbackTimer) {
        window.clearTimeout(fallbackTimer);
        fallbackTimer = 0;
      }

      isSubmitting = false;
      signupButton.disabled = false;
      signupButton.textContent = "Join The Mailing List";
      signupForm.reset();
      signupMessage.textContent = message;
      signupMessage.classList.remove("hidden");
    };

    signupFrame.addEventListener("load", () => {
      if (!isSubmitting) return;
      finalizeSubmission("Submission received. Watch your inbox for Rust India updates.");
    });

    signupForm.addEventListener("submit", (event) => {
      if (isSubmitting) {
        event.preventDefault();
        return;
      }

      isSubmitting = true;
      signupButton.disabled = true;
      signupButton.textContent = "Sending...";
      signupMessage.classList.add("hidden");

      fallbackTimer = window.setTimeout(() => {
        if (!isSubmitting) return;
        finalizeSubmission("Submission sent. If nothing arrives later, please try again.");
      }, 4500);
    });
  }
</script>
