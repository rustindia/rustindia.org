---
import ferrisBadge from "../assets/mascot.png";

const ferrisBadgeSrc = typeof ferrisBadge === "string" ? ferrisBadge : ferrisBadge.src;
---

<section class="home-hero section-shell">
  <p class="section-label">Rust India Conference 2026</p>
  <h1 class="home-hero__title">Rust India Conference 2026</h1>

  <div class="home-hero__art frame-panel">
    <img src={ferrisBadgeSrc} alt="Ferris badge for Rust India 2026" />
  </div>

  <p class="home-hero__lede">
    Bringing systems engineers, tooling teams, and Rust contributors to Bengaluru for a focused day of talks,
    community, and hiring conversations around real Rust work.
  </p>
  <div class="home-hero__actions">
    <a href="https://hasgeek.com/rustbangalore/rust-india-conference-2026/" class="btn btn-primary home-hero__ticket-cta">Book Tickets Now</a>
  </div>

  <div class="home-hero__actions">
    <a href="/schedule" class="btn btn-secondary">View Schedule</a>
    <a href="#mailing-list" class="btn btn-secondary">Get Updates</a>
  </div>
</section>
