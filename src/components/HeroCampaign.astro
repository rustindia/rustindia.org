---
import ferrisMascot from "../assets/mascot.png";

const ferrisMascotSrc = typeof ferrisMascot === "string" ? ferrisMascot : ferrisMascot.src;
---

<section class="home-hero section-shell">
  <p class="section-label">Rust India Conference 2026</p>
  <h1 class="home-hero__title">Rust India Conference 2026</h1>

  <div class="home-hero__art frame-panel home-hero__banner">
    <div class="home-hero__banner-copy">
      <p class="home-hero__banner-kicker">Rust India 2026</p>
      <p class="home-hero__banner-days">Last few weeks left.</p>
      <p class="home-hero__banner-open">Tickets open now!!</p>
    </div>

    <img src={ferrisMascotSrc} alt="Ferris Mascot Rust India 2026" aria-hidden="true" />
  </div>

  <p class="home-hero__lede">
    Bringing systems engineers, tooling teams, and Rust contributors to Bengaluru for a focused day of talks,
    community, and hiring conversations around real Rust work.
  </p>

</section>
