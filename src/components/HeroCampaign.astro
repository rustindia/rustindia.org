<script>
  const targetDate = new Date("2026-04-18T09:00:00+05:30").getTime();
  const countdownNode = document.querySelector("[data-countdown]");

  if (countdownNode) {
    let intervalId = 0;

    const render = () => {
      const now = Date.now();
      const distance = Math.max(0, targetDate - now);
      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((distance / (1000 * 60)) % 60);
      const seconds = Math.floor((distance / 1000) % 60);

      if (distance === 0) {
        countdownNode.textContent = "Live now";
        if (intervalId) {
          window.clearInterval(intervalId);
          intervalId = 0;
        }
        return;
      }

      countdownNode.textContent = `${days}d ${String(hours).padStart(2, "0")}h ${String(minutes).padStart(2, "0")}m ${String(seconds).padStart(2, "0")}s`;
    };

    render();
    intervalId = window.setInterval(render, 1000);

    window.addEventListener(
      "pagehide",
      () => {
        if (intervalId) {
          window.clearInterval(intervalId);
        }
      },
      { once: true }
    );
  }
</script>
