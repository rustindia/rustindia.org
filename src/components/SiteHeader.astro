---
import ferrisBadge from "../assets/ferris/ferris-badge.svg";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const ferrisSrc = typeof ferrisBadge === "string" ? ferrisBadge : ferrisBadge.src;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/schedule", label: "Schedule" },
  { href: "/sponsors", label: "Sponsors" },
  { href: "/jobs", label: "Jobs" },
];
---

<header class="site-header">
  <div class="section-shell site-header__bar">
    <a href="/" class="site-header__brand">
      <img src={ferrisSrc} alt="Ferris" class="brand-mark" />
      <span class="brand-copy">
        <strong>Rust India 2026</strong>
        <span>Bengaluru | April 18</span>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      {
        navItems.map((item) => (
          <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="site-header__actions">
      <a class="btn btn-primary" href="https://discord.com/invite/p3uaTXS6NP" target="_blank" rel="noreferrer">Join Discord</a>

      <details class="header-menu" data-mobile-menu>
        <summary class="btn btn-secondary" aria-label="Open navigation menu">Menu</summary>
        <div class="header-menu__panel">
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
          <a href="https://discord.com/invite/p3uaTXS6NP" target="_blank" rel="noreferrer">Join Discord</a>
        </div>
      </details>
    </div>
  </div>
</header>
