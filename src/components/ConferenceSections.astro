<section class="section-shell grid gap-6 pb-16 md:grid-cols-2 md:pb-20">
  <article id="cfp" class="hero-glass rounded-3xl p-6 md:p-7">
    <p class="text-xs uppercase tracking-[0.18em] text-rust-200">CFP Is Open</p>
    <h2 class="mt-3 font-display text-3xl font-semibold text-rust-50">Share your Rust story on stage</h2>
    <p class="mt-3 text-rust-100/90">
      We want practical talks: migration journeys, performance wins, hard production lessons, tooling, and developer
      experience. First-time speakers are welcome.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href="https://sessionize.com/" class="cta-button cta-primary" target="_blank" rel="noreferrer">
        Submit CFP
      </a>
      <span class="rounded-full border border-white/20 bg-black/25 px-4 py-2 text-sm text-rust-100">20 or 40 min talks</span>
    </div>
  </article>

  <article id="mailing-list" class="hero-glass rounded-3xl p-6 md:p-7">
    <p class="text-xs uppercase tracking-[0.18em] text-rust-200">Mailing List</p>
    <h2 class="mt-3 font-display text-3xl font-semibold text-rust-50">Get ticket and schedule updates</h2>
    <p class="mt-3 text-rust-100/90">Be the first to know when tickets drop, agenda lands, and speakers are announced.</p>
    <form class="mt-6 flex flex-col gap-3 sm:flex-row" action="#" method="post">
      <label class="sr-only" for="email">Email</label>
      <input
        id="email"
        type="email"
        required
        placeholder="you@company.com"
        class="w-full rounded-full border border-white/20 bg-black/30 px-5 py-3 text-rust-50 placeholder:text-rust-100/65 focus:border-rust-300 focus:outline-none"
      />
      <button type="submit" class="cta-button cta-primary">Sign Up</button>
    </form>
    <p data-signup-msg class="mt-2 hidden text-sm text-rust-200">Thanks! We will keep you in the loop.</p>
  </article>

  <article class="hero-glass rounded-3xl p-6 md:p-7">
    <p class="text-xs uppercase tracking-[0.18em] text-rust-200">Conference Snapshot</p>
    <h2 class="mt-3 font-display text-3xl font-semibold text-rust-50">One day. Focused and high-signal.</h2>
    <div class="mt-4 grid gap-3 text-rust-100/95 sm:grid-cols-3 md:grid-cols-1 lg:grid-cols-3">
      <div class="rounded-2xl border border-white/15 bg-black/20 p-4">
        <p class="text-xs uppercase tracking-wider text-rust-200">Date</p>
        <p class="mt-1 font-display text-xl text-rust-50">18 Apr 2026</p>
      </div>
      <div class="rounded-2xl border border-white/15 bg-black/20 p-4">
        <p class="text-xs uppercase tracking-wider text-rust-200">Day</p>
        <p class="mt-1 font-display text-xl text-rust-50">Saturday</p>
      </div>
      <div class="rounded-2xl border border-white/15 bg-black/20 p-4">
        <p class="text-xs uppercase tracking-wider text-rust-200">Venue City</p>
        <p class="mt-1 font-display text-xl text-rust-50">Bangalore</p>
      </div>
    </div>
  </article>

  <article id="sponsors" class="hero-glass rounded-3xl p-6 md:p-7">
    <p class="text-xs uppercase tracking-[0.18em] text-rust-200">Sponsors</p>
    <h2 class="mt-3 font-display text-3xl font-semibold text-rust-50">Partner with Rust India</h2>
    <p class="mt-3 text-rust-100/90">
      Reach a focused audience of developers and engineering leaders. We have sponsor options for brand presence,
      developer hiring, and community support.
    </p>
    <div class="mt-4 flex flex-wrap gap-2 text-sm text-rust-100/95">
      <span class="rounded-full border border-white/20 bg-black/25 px-3 py-1">Hiring spotlight</span>
      <span class="rounded-full border border-white/20 bg-black/25 px-3 py-1">Booth and demos</span>
      <span class="rounded-full border border-white/20 bg-black/25 px-3 py-1">Talk sponsorship</span>
    </div>
    <a href="mailto:sponsors@rustindia.dev" class="cta-button cta-primary mt-6">Reach Out To Sponsor</a>
  </article>
</section>

<script>
  const signupForm = document.querySelector("#mailing-list form");
  const signupMessage = document.querySelector("[data-signup-msg]");

  if (signupForm && signupMessage) {
    signupForm.addEventListener("submit", (event) => {
      event.preventDefault();
      signupMessage.classList.remove("hidden");
      signupForm.reset();
    });
  }
</script>
